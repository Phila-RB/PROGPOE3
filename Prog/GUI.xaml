<Window x:Class="Prog.GUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prog"
        mc:Ignorable="d"
        Title="GUI" Height="800" Width="1200">
    <!--grid 1-->
    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition  Width ="150"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <!--grid 2-->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0">
                <StackPanel x:Name="msgView" Background="WhiteSmoke" CanVerticallyScroll="True">
                </StackPanel>
            </ScrollViewer>
            <!--grid 3-->
            <Grid Grid.Row="1" Background="LightBlue">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="msgBox" Text="{Binding Msgs}" Grid.Column ="0" Height="30" VerticalAlignment="Top" Margin="20"></TextBox>
                <Button Name="sendBut" Content="Send" Grid.Column="1" Height="30" VerticalAlignment="Top" Margin="20" FontSize="20" FontWeight="Bold" Click="Button_Click"></Button>
            </Grid>
        </Grid>
        <StackPanel Orientation="Vertical">
            <Label Content="CYBER" Foreground="White" FontSize="40" HorizontalAlignment="Center"></Label>
            <Label Content="HELP" Foreground="White" FontSize="40" HorizontalAlignment="Center"></Label>
        </StackPanel>
    </Grid>
</Window>
